{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "node_modules/.tmp/tsconfig-node/tsconfig.node.tsbuildinfo",
    "outDir": "node_modules/.tmp/tsconfig-node",
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "allowSyntheticDefaultImports": true
  },
  "include": ["vite.config.ts", "server/**/*.ts"]
}
